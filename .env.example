# =============================================================================
# Pladigit — Configuration d'environnement
# Copier ce fichier en .env et compléter les valeurs
# NE JAMAIS committer le fichier .env en production
# =============================================================================

# --- Application ---
APP_NAME="Pladigit"
APP_ENV=production
APP_KEY=                          # généré par : php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_URL=https://pladigit.fr       # URL racine — pas de slash final

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# --- Sécurité ---
BCRYPT_ROUNDS=12                  # 12 en production, 4 en test

# --- Base de données centrale (plateforme) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pladigit_platform
DB_USERNAME=pladigit
DB_PASSWORD=                      # mot de passe fort

# --- Base de données tenant (connexion dynamique) ---
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_USERNAME=pladigit
TENANT_DB_PASSWORD=               # identique à DB_PASSWORD si même serveur

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                   # mot de passe Redis (recommandé)
REDIS_PORT=6379

# --- Sessions, Cache, Queue ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120              # minutes
SESSION_ENCRYPT=true
SESSION_DOMAIN=.pladigit.fr       # domaine wildcard pour les sous-domaines tenant

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# --- Super Admin ---
# Le Super Admin n'est PAS en base de données — uniquement dans .env
SUPER_ADMIN_EMAIL=superadmin@pladigit.fr
SUPER_ADMIN_PASSWORD=             # mot de passe très fort — changer immédiatement

# --- Email (SMTP) ---
# Configuré par organisation via l'interface Super Admin
# Ces valeurs sont des fallbacks pour les emails système (invitations, etc.)
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="contact@pladigit.fr"
MAIL_FROM_NAME="Pladigit"

# --- Collabora Online (optionnel) ---
# Laisser vide pour désactiver l'édition collaborative
COLLABORA_URL=                    # ex: https://collabora.pladigit.fr
WOPI_URL=https://pladigit.fr      # URL fixe pour WOPISrc (accessible depuis Collabora)
COLLABORA_EDITOR_PATH=/browser/dist/cool.html
COLLABORA_TOKEN_TTL=14400         # secondes (4 heures)

# --- Logs ---
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning                 # debug en dev, warning en prod

# --- Maintenance ---
APP_MAINTENANCE_DRIVER=file

# =============================================================================
# Notes pour la production
# =============================================================================
# 1. APP_DEBUG=false obligatoire en production
# 2. SESSION_DOMAIN doit être .pladigit.fr (avec le point) pour les sous-domaines
# 3. COLLABORA_URL vide = bouton "Ouvrir dans Collabora" absent de l'interface
# 4. Adapter les mots de passe DB/Redis — ne jamais utiliser les valeurs par défaut
# 5. Le scheduler Laravel doit tourner : * * * * * php artisan schedule:run
# 6. Le queue worker doit tourner via Supervisor (voir INSTALL.md)
# =============================================================================
