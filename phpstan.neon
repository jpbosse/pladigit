includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    treatPhpDocTypesAsCertain: false
    paths:
        - app
    level: 5
    parallel:
        maximumNumberOfProcesses: 1
    stubFiles:
        - stubs/smbclient.php
    ignoreErrors:
        -
            message: '#^Function smbclient_[a-z_]+ not found\.$#'
            path: app/Services/Nas/SmbNasDriver.php
        -
            message: '#^Constant SMBCLIENT_[A-Z_]+ not found\.$#'
            path: app/Services/Nas/SmbNasDriver.php
            reportUnmatched: false
        # Relations Eloquent — PHPStan ne résout pas correctement les génériques
        # BelongsToMany et HasMany avec connexion tenant non standard
        -
            message: '#^Method App\\Models\\Tenant\\Project::(members|projectMembers|tasks|rootTasks|milestones|events)\(\) should return#'
            path: app/Models/Tenant/Project.php
            reportUnmatched: false
        -
            message: '#Generic type Illuminate\\Database\\Eloquent\\Relations\\(HasMany|BelongsToMany)#'
            path: app/Models/Tenant/Project.php
            reportUnmatched: false
        -
            message: '#^Method App\\Models\\Tenant\\Task::(children|allChildren|comments|blockedBy|blocking)\(\) should return#'
            path: app/Models/Tenant/Task.php
            reportUnmatched: false
        -
            message: '#Generic type Illuminate\\Database\\Eloquent\\Relations\\(HasMany|BelongsToMany)#'
            path: app/Models/Tenant/Task.php
            reportUnmatched: false
        -
            message: '#^Method App\\Models\\Tenant\\ProjectMilestone::(tasks|children)\(\) should return#'
            path: app/Models/Tenant/ProjectMilestone.php
            reportUnmatched: false
        -
            message: '#Generic type Illuminate\\Database\\Eloquent\\Relations\\HasMany#'
            path: app/Models/Tenant/ProjectMilestone.php
            reportUnmatched: false
        # MediaService — variable $thumbPath — bug préexistant hors scope Phase 5bis
        -
            message: '#^(Undefined variable|Variable .+ might not be defined)#'
            path: app/Services/MediaService.php
            reportUnmatched: false
    excludePaths:
        analyseAndScan:
            - app/Http/Middleware/TrustProxies.php (?)
